HOST=0.0.0.0
PORT=8443

# Minimum 32 znaki. Ten sekret sluzy tylko do autoryzacji dostepu do relay.
# Nie jest uzywany do szyfrowania tresci rozmow.
RELAY_TOKEN=zmien-ten-token-na-losowy-ciag-minimum-32-znaki

# Limit pojedynczego pakietu WebSocket. Zwieksz ostroznie przy duzych plikach.
MAX_PAYLOAD_BYTES=16777216

# Ograniczenia anty-naduzyciowe per polaczenie.
RATE_LIMIT_MESSAGES=80
RATE_LIMIT_WINDOW_MS=10000
MAX_CONNECTIONS_PER_USER=4

# Domyslnie serwer nie loguje ruchu uzytkownikow.
SECURITY_LOGS=false

# Publiczna lista uzytkownikow opt-in. Zawiera tylko userId, nazwe i klucz publiczny.
PUBLIC_DIRECTORY_FILE=./data/public-directory.json

# Trwala lista userId widzianych przez relay. Bez kluczy prywatnych i bez tresci rozmow.
KNOWN_USERS_FILE=./data/known-users.json

# Lista zablokowanych userId zarzadzana narzedziem: npm run admin:users -- ...
BANNED_USERS_FILE=./data/banned-users.json

# Aktualizacje aplikacji. Manifest opisuje najnowsza wersje, a pliki leza w katalogu files.
UPDATE_MANIFEST_FILE=./updates/manifest.json
UPDATE_FILES_DIR=./updates/files
