HOST=127.0.0.1
PORT=8443
TRUSTED_PROXIES=127.0.0.1,::1,::ffff:127.0.0.1

# Rejestracja: disabled, invite albo open. Zaproszenia tworzy endpoint /v2/admin/invites.
REGISTRATION_MODE=disabled

# Osobny sekret endpointu /v2/admin/invites. Ustaw losowy ciag minimum 32 znaki.
ADMIN_TOKEN=zmien-ten-admin-token-na-losowy-ciag-minimum-32-znaki
METRICS_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# Limit zaszyfrowanej koperty wiadomosci. Plik 10 MB po szyfrowaniu i base64
# zajmuje wiecej, dlatego serwer przyjmuje do 32 MB pakietu.
MAX_PAYLOAD_BYTES=33554432
WS_PREAUTH_TIMEOUT_MS=5000
WS_PREAUTH_MAX_GLOBAL=500
WS_PREAUTH_MAX_PER_IP=8
WS_PREAUTH_MAX_PER_WINDOW=30
WS_PREAUTH_WINDOW_MS=10000
WS_PREAUTH_MAX_UNIQUE_IPS=10000

# Dane backendu kont i zaszyfrowanej historii.
V2_DATA_DIR=./data-v2
MESSAGE_MAX_BYTES=33554432
MESSAGES_PER_CONVERSATION=50000
CONVERSATION_QUOTA_BYTES=268435456
ACCOUNT_QUOTA_BYTES=1073741824
INSTANCE_QUOTA_BYTES=10737418240
DAILY_ACCOUNT_QUOTA_BYTES=104857600
MIN_FREE_DISK_BYTES=536870912

# Aktualizacje aplikacji. Manifest opisuje najnowsza wersje, a pliki leza w katalogu files.
UPDATE_MANIFEST_FILE=./updates/manifest.json
UPDATE_FILES_DIR=./updates/files
